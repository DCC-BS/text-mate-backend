# @defaultRequired=true
# ---

# The client ID for Azure AD application
# @required @type=uuid
AZURE_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/CLIENT_ID`)

# The tenant ID for Azure AD application
# @required @type=uuid
AZURE_TENANT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/TENANT_ID`)

# The client ID for Azure AD frontend application
# @required @type=uuid
AZURE_FRONTEND_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/FRONTEND_CLIENT_ID`)

# The scope description for Azure AD authentication
AZURE_SCOPE_DESCRIPTION=user_impersonation
