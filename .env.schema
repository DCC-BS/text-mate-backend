# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# 
# @defaultRequired=infer @defaultSensitive=false
# ----------

# The application environment
# @type=enum(development, production)
ENVIRONMENT=development

# The model for LLM API
# @required @type=string
LLM_MODEL=

# The URL for LLM API
# @required @type=url
LLM_URL=

# The API key for authenticating with OpenAI
# @required @sensitive
LLM_API_KEY=

# The URL for client application
# @type=url
CLIENT_URL=if(
	eq($ENVIRONMENT, "development"), http://localhost:3000, )

# The URL for Language Tool API
# @type=url
LANGUAGE_TOOL_API_URL=if(
	eq($ENVIRONMENT, "development"), http://localhost:8010/v2, )

# The URL for Docling service
# @type=url
DOCLING_URL=if(
	eq($ENVIRONMENT, "development"), http://localhost:5001/v1, )

# The URL for LLM health check API
# @type=url
LLM_HEALTH_CHECK_URL=if(
	eq($ENVIRONMENT, "development"), http://localhost:8001/health, )

# The client ID for Azure AD application
# @required @type=uuid
AZURE_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/CLIENT_ID`)

# The tenant ID for Azure AD application
# @required @type=uuid
AZURE_TENANT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/TENANT_ID`)

# The client ID for Azure AD frontend application
# @required @type=uuid
AZURE_FRONTEND_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/FRONTEND_CLIENT_ID`)

# Used to pseudonymize user id. Create with openssl rand 32 | base64
# @required @sensitive
HMAC_SECRET=

# The scope description for Azure AD authentication
AZURE_SCOPE_DESCRIPTION=user_impersonation

# Flag to disable authentification
# @type=enum(True, False)
DISABLE_AUTH=True

# Flag to indicate if the environment is production
# @type=enum(True, False)
IS_PROD=ifs(
	eq($ENVIRONMENT, "development"),  False,
	eq($ENVIRONMENT, "production"), True,
	False
)
